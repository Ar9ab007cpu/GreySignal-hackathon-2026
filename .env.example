GREYSIGNAL_API_URL=http://127.0.0.1:8010
HTTP_TIMEOUT_SECONDS=30

WORLD_BANK_BASE_URL=https://api.worldbank.org/v2
WORLD_BANK_DOCS_URL=https://search.worldbank.org/api/v3/wds
GDELT_DOC_URL=https://api.gdeltproject.org/api/v2/doc/doc
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
# MediaStack is the primary news source; GDELT is a fallback (its public API often returns HTTP 429).
MEDIASTACK_API_URL=http://api.mediastack.com/v1/news
MEDIASTACK_API_KEY=your_mediastack_key_here
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search

EXCHANGE_RATE_API_BASE_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_RATE_API_KEY=your_exchange_rate_key_here

UN_COMTRADE_URL=https://comtradeapi.un.org/data/v1/get/C/A/HS
UN_COMTRADE_API_KEY=your_un_comtrade_key_here

GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=your_groq_key_here

ACLED_API_URL=https://acleddata.com/api/acled/read
